# Football AI Vision Analytics Configuration
# Copy this file to .env and update values as needed
# These settings override defaults in config.py

# Input/Output files
VIDEO_PATH=football_video.mp4
MODEL_PATH=best_100e.pt
OUTPUT_DIR=output_videos
DEMO_DIR=demo_dashboard

# YOLO Detection Parameters
YOLO_CONF=0.10
YOLO_IOU=0.5
YOLO_IMGSZ=1280
YOLO_DEVICE=cpu
YOLO_TRACKER=bytetrack.yaml

# Processing Parameters
FRAME_WINDOW=5
MAX_SPEED_KMH=45
MIN_TRACK_DURATION=0.5
MAX_SPEED_GAP_FRAMES=30

# Field Calibration
FIELD_WIDTH_METERS=68

# Visualization
DISTANCE_THRESHOLD_PIXELS=60

# Debugging
DEBUG_MODE=false
